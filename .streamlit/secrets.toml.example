# Copy to .streamlit/secrets.toml

GEMINI_API_KEY = "your-gemini-api-key"
APP_USERNAME = "hr"
APP_PASSWORD = "your-secure-password"

# Email (Gmail example — use App Password)
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = 587
SMTP_USER = "hr@yourcompany.com"
SMTP_PASSWORD = "your-app-password"
SMTP_FROM = "DABOUQ HR <hr@yourcompany.com>"
HR_EMAIL = "hr@yourcompany.com"

# Public URL for candidate accept/reject links
APP_BASE_URL = "https://your-app.streamlit.app"
